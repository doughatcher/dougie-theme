{
  "version": "2.3.0",
  "title": "Dougie",
  "description": "Versatile two-column theme that carries both a microblog timeline and a long-form publication on the same site. Configurable sidebar with profile, social links, From the Blog, Recent Publications, and RSS. Default and Starfield Dreams variants (visitor-selectable). All branding and social links are per-site fields — same theme, multiple sites, no forking.",
  "fields": [
    {
      "field": "params.avatar",
      "label": "Profile / brand image URL",
      "placeholder": "Absolute URL to a circular profile photo or square brand mark."
    },
    {
      "field": "params.show_avatar",
      "label": "Show profile image",
      "type": "boolean"
    },
    {
      "field": "params.bio",
      "label": "Site bio / tagline",
      "placeholder": "One-line tagline shown under the site title."
    },
    {
      "field": "params.show_bio",
      "label": "Show bio under site title",
      "type": "boolean"
    },
    {
      "field": "params.show_social_links",
      "label": "Show social links in sidebar + footer",
      "type": "boolean"
    },
    {
      "field": "params.linkedin_url",
      "label": "LinkedIn URL",
      "placeholder": "https://linkedin.com/in/yourhandle"
    },
    {
      "field": "params.bluesky_url",
      "label": "Bluesky URL",
      "placeholder": "https://bsky.app/profile/yourhandle.bsky.social"
    },
    {
      "field": "params.threads_url",
      "label": "Threads URL",
      "placeholder": "https://www.threads.com/@yourhandle"
    },
    {
      "field": "params.mastodon_url",
      "label": "Mastodon URL",
      "placeholder": "https://mastodon.social/@yourhandle"
    },
    {
      "field": "params.twitter_url",
      "label": "Twitter / X URL",
      "placeholder": "https://twitter.com/yourhandle"
    },
    {
      "field": "params.github_url",
      "label": "GitHub URL",
      "placeholder": "https://github.com/yourhandle"
    },
    {
      "field": "params.instagram_url",
      "label": "Instagram URL",
      "placeholder": "https://instagram.com/yourhandle"
    },
    {
      "field": "params.youtube_url",
      "label": "YouTube URL",
      "placeholder": "https://www.youtube.com/@yourhandle"
    },
    {
      "field": "params.microblog_url",
      "label": "Micro.blog URL",
      "placeholder": "https://micro.blog/yourhandle"
    },
    {
      "field": "params.email_url",
      "label": "Email address",
      "placeholder": "you@example.com (mailto: prefix added automatically)"
    },
    {
      "field": "params.show_publications_sidebar",
      "label": "Show \"Recent Publications\" sidebar block",
      "type": "boolean"
    },
    {
      "field": "params.show_floating_nav",
      "label": "Show floating navigation",
      "type": "boolean"
    },
    {
      "field": "params.show_dark_mode_toggle",
      "label": "Show light/dark mode toggle",
      "type": "boolean"
    },
    {
      "field": "params.show_word_count",
      "label": "Show word count on long posts",
      "type": "boolean"
    },
    {
      "field": "params.show_reading_time",
      "label": "Show reading time on long posts",
      "type": "boolean"
    },
    {
      "field": "params.show_thumbnails",
      "label": "Show post thumbnails",
      "type": "boolean"
    }
  ]
}
